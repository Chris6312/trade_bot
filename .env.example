APP_NAME=Small Account Multi-Asset Trading Bot
APP_ENV=development
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8101
FRONTEND_PORT=4174
POSTGRES_DB=tradingbot
POSTGRES_USER=tradingbot
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=55432
DATABASE_URL=postgresql+psycopg://tradingbot:change-me@postgres:5432/tradingbot
CORS_ORIGINS=http://localhost:4174,http://127.0.0.1:4174
VITE_API_BASE_URL=http://localhost:8101

ALPACA_PAPER_KEY=your_alpaca_paper_key_here
ALPACA_PAPER_SECRET=your_alpaca_paper_secret_here
ALPACA_PAPER_KEY_CRYPTO=your_alpaca_crypto_key_here
ALPACA_PAPER_SECRET_CRYPTO=your_alpaca_crypto_secret_here
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here
PUBLIC_API_SECRET=your_public_api_secret_here
PUBLIC_ACCOUNT_ID=
PUBLIC_ACCESS_TOKEN_VALIDITY_MINUTES=60
KRAKEN_API_BASE_URL=https://api.kraken.com/0
ALPACA_TRADING_API_BASE_URL=https://paper-api.alpaca.markets
ALPACA_MARKET_DATA_BASE_URL=https://data.alpaca.markets
PUBLIC_API_BASE_URL=https://api.public.com
BROKER_REQUEST_TIMEOUT_SECONDS=10
KRAKEN_QUOTE_CURRENCY=ZUSD
KRAKEN_TRADE_BALANCE_ASSET=ZUSD
# OpenAI 
AI_PROVIDER=openai
AI_MODEL=gpt-5-mini
AI_ENABLED=true
AI_RUN_ONCE_DAILY=true
AI_PREMARKET_TIME_ET=08:40
AI_INFLUENCE_ENABLED=false
AI_INFLUENCE_MAX_DELTA_COMPOSITE=0.05
AI_API_URL=https://api.openai.com/v1
AI_API_KEY=openai api key here
STOCK_UNIVERSE_SOURCE=ai

STOCK_DEFAULT_BACKFILL_BARS=500
CRYPTO_DEFAULT_BACKFILL_BARS=720
